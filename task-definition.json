{
  "family": "resume-app-task",
  "networkMode": "bridge",
  "containerDefinitions": [
    {
      "name": "resume-app-container",
      "image": "IMAGE_PLACEHOLDER",
      "essential": true,
      "memory": 256,
      "cpu": 128,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ]
    }
  ]
}